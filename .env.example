# HuggingFace API Token (free at https://huggingface.co/settings/tokens)
HUGGINGFACEHUB_API_TOKEN=hf_your_token_here

# Tavily API (free tier at https://tavily.com)
TAVILY_API_KEY=tvly_your_key_here

# Optional: ChromaDB storage path (default: ./chroma_db)
CHROMA_PERSIST_DIR=./chroma_db

# LLM models (defaults shown)
PRIMARY_MODEL=Qwen/Qwen2.5-7B-Instruct
FALLBACK_MODEL=microsoft/Phi-3.5-mini-instruct
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
